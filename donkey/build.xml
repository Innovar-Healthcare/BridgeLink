			<param name="db.type" value="postgres"/>
		</antcall>
		<antcall target="test-run-db-only">
			<param name="db.type" value="postgres"/>
		</antcall>
		<antcall target="docker-cleanup-db">
			<param name="db.type" value="postgres"/>
		</antcall>
	</target>

	<target name="test-run-mysql-db" depends="test-compile" description="Run tests against MySQL database">
