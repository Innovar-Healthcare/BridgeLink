	<target name="test-run-oracle-db" depends="test-compile" description="Run tests against Oracle database">
		<echo message=""/>
		<echo message="[5/5] Testing Oracle..."/>
		<antcall target="docker-start-db">
			<param name="db.type" value="oracle"/>
		</antcall>
		<antcall target="test-run-db-only">
			<param name="db.type" value="oracle"/>
		</antcall>
<!--		<antcall target="docker-cleanup-db">-->
<!--			<param name="db.type" value="oracle"/>-->
<!--		</antcall>-->
	</target>

	<target name="test-run-all-databases" depends="clean-test-reports" description="Run tests against all database types (one at a time)">
		<echo message=""/>
		<echo message="========================================"/>
		<echo message="Running tests against all databases"/>
		<echo message="(one at a time with cleanup)"/>
		<echo message="========================================"/>
		<echo message=""/>

		<antcall target="test-run-derby-db"/>
		<antcall target="test-run-postgres-db"/>
		<antcall target="test-run-mysql-db"/>
		<antcall target="test-run-sqlserver-db"/>
		<antcall target="test-run-oracle-db"/>

		<echo message=""/>
		<echo message="========================================"/>
		<echo message="All database tests completed!"/>
		<echo message="========================================"/>
		<echo message="Reports generated in:"/>
		<echo message="  - junit-html-derby/index.html"/>
		<echo message="  - junit-html-postgres/index.html"/>
		<echo message="  - junit-html-mysql/index.html"/>
		<echo message="  - junit-html-sqlserver/index.html"/>
		<echo message="  - junit-html-oracle/index.html"/>
		<echo message="========================================"/>
	</target>

	<target name="clean-test-reports" description="Clean all test reports for all databases">
		<delete dir="junit-reports" />
		<delete dir="junit-html" />
		<delete dir="code-coverage-reports" />
		<delete dir="jacoco-html" />

		<delete dir="junit-reports-derby" />
