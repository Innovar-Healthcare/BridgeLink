<project name="mirth-connect" basedir="." default="build">
	<target name="init">
		<property file="mirth-build.properties" />
		<property name="donkey.setup" value="${donkey}/setup" />
		<property name="server.setup" value="${server}/setup" />
		<property name="server.build" value="${server}/build" />
	</target>
	
	<!-- Donkey -->
	<target name="build-donkey" depends="init">
		<ant antfile="${donkey}/build.xml" dir="${donkey}" target="build" />
		
		<delete dir="${server}/lib/donkey" />
		<copy file="${donkey.setup}/donkey-model.jar" todir="${server}/lib/donkey" />
		<copy file="${donkey.setup}/donkey-server.jar" todir="${server}/lib/donkey" />
		<copy todir="${server}/lib/donkey">
			<fileset dir="${donkey}/lib">
				<exclude name="log4j-1.2.16.jar" />
				<exclude name="HikariCP-java6-2.0.1.jar" />
				<exclude name="javassist-3.19.0-GA.jar" />
				<exclude name="xstream/**" />
				<exclude name="commons/**" />
				<exclude name="database/**" />
			</fileset>
		</copy>
	</target>
	
	<!-- WebAdmin -->
	<target name="build-webadmin" depends="init">
		<ant antfile="${webadmin}/build.xml" dir="${webadmin}" target="dist"/>
		<copy file="${webadmin}/dist/webadmin.war" todir="${server.build}/webapps" />
		<copy file="${webadmin}/dist/webadmin.war" todir="${server.setup}/webapps" />
	</target>
	
	<!-- Server extensions -->
	<target name="build-server-extensions" depends="build-donkey">
		<ant antfile="${server}/build.xml" dir="${server}" target="create-plugins" />

		<!-- copy the shared extension jars to the client lib -->
		<copy todir="${client}/lib" flatten="true">
			<fileset dir="${server.build}/extensions/">
				<include name="**/*-shared.jar" />
			</fileset>
		</copy>
	</target>

	<!-- Client -->
	<target name="build-client" depends="build-server-extensions">
		<copy file="${donkey.setup}/donkey-model.jar" todir="${client}/lib" />
		<copy file="${server.setup}/server-lib/mirth-client-core.jar" todir="${client}/lib" />
		<copy file="${server.setup}/server-lib/mirth-crypto.jar" todir="${client}/lib" />
		<copy file="${server}/lib/mirth-vocab.jar" todir="${client}/lib" />

		<ant antfile="${client}/ant-build.xml" dir="${client}" target="build" />

		<copy file="${client}/dist/mirth-client.jar" todir="${server.setup}/client-lib/" />

		<copy todir="${server.setup}/client-lib">
			<fileset dir="${client}/lib">
				<exclude name="*-shared.jar" />
				<exclude name="extensions" />
			</fileset>
		</copy>
		
		<copy todir="${server.setup}/extensions">
			<fileset dir="${client}/dist/extensions" />
		</copy>
	</target>

	<!-- Manager -->
	<target name="build-manager" depends="build-client">
		<copy file="${donkey.setup}/donkey-model.jar" todir="${manager}/lib" />
		<copy file="${server.setup}/server-lib/mirth-client-core.jar" todir="${manager}/lib" />
		<copy file="${server.setup}/server-lib/mirth-crypto.jar" todir="${manager}/lib" />

		<ant antfile="${manager}/ant-build.xml" dir="${manager}" target="build" />

		<copy file="${manager}/dist/mirth-manager-launcher.jar" todir="${server.setup}" />

		<copy todir="${server.setup}/manager-lib">
			<fileset dir="${manager}/lib">
				<exclude name="mirth-client.jar" />
			</fileset>
		</copy>
	</target>

	<!-- CLI -->
	<target name="build-cli" depends="build-client">
		<copy file="${donkey.setup}/donkey-model.jar" todir="${cli}/lib" />
		<copy file="${server.setup}/server-lib/mirth-client-core.jar" todir="${cli}/lib" />
		<copy file="${server.setup}/server-lib/mirth-crypto.jar" todir="${cli}/lib" />

		<ant antfile="${cli}/build.xml" dir="${cli}" target="build">
			<property name="version" value="${version}" />
		</ant>
		
		<copy todir="${server.setup}/cli-lib">
			<fileset dir="${cli}/build">
				<include name="mirth-cli.jar" />
			</fileset>
		</copy>

		<copy todir="${server.setup}">
			<fileset dir="${cli}/build">
				<include name="mirth-cli-launcher.jar" />
			</fileset>
		</copy>

		<copy todir="${server.setup}/cli-lib">
			<fileset dir="${cli}/lib">
				<exclude name="mirth-client.jar" />
			</fileset>
		</copy>

		<copy todir="${server.setup}/conf">
			<fileset dir="${cli}/conf">
				<include name="mirth-cli-config.properties" />
				<include name="log4j2-cli.properties" />
			</fileset>
		</copy>
	</target>

	<target name="build" depends="build-manager, build-cli, build-webadmin">
		<ant antfile="${server}/build.xml" dir="${server}" target="create-setup">
			<property name="version" value="${version}" />
		</ant>
		
		<copy todir="${server.build}/extensions/">
			<fileset dir="${server.setup}/extensions/" />
		</copy>

		<copy todir="${server.build}/client-lib">
			<fileset dir="${server.setup}/client-lib" />
		</copy>
		
		<antcall target="test-run" />
	</target>

	<target name="dist" depends="build-manager, build-cli, build-webadmin">
		<echo>Application version: ${version}</echo>

		<ant antfile="${server}/build.xml" dir="${server}" target="create-dist">
			<property name="version" value="${version}" />
		</ant>
	</target>

	<target name="append-license" depends="init">
		<path id="header.classpath">
			<fileset dir="${server}/lib">
				<include name="**/*.jar" />
			</fileset>
		</path>

		<taskdef name="header" classname="com.mirth.tools.header.HeaderTask">
			<classpath refid="header.classpath" />
		</taskdef>

		<header headerFile="${server}/license-header.txt">
			<fileset dir="${server}" includes="**/*.java" excludes="src/io/**/*.java src/org/**/*.java src/com/mirth/connect/server/logging/LogOutputStream.java" />
		</header>

		<header headerFile="${server}/license-header.txt">
			<fileset dir="${client}" includes="**/*.java" excludes="src/com/mirth/connect/client/ui/BareBonesBrowserLaunch.java src/com/mirth/connect/client/ui/BeanBinder.java src/com/mirth/connect/client/ui/OSXAdapter.java src/org/**/*.java" />
		</header>
		
		<header headerFile="${server}/license-header.txt">
				<fileset dir="${cli}" includes="**/*.java" />
		</header>

		<header headerFile="${server}/license-header.txt">
			<fileset dir="${manager}" includes="**/*.java" excludes="src/com/mirth/connect/manager/BareBonesBrowserLaunch.java" />
		</header>
		
		<header headerFile="${server}/license-header.txt">
			<fileset dir="${donkey}" includes="**/*.java" />
		</header>
		
		<header headerFile="${server}/license-header.txt">
			<fileset dir="${webadmin}" includes="**/*.java" />
		</header>
	</target>

	<target name="test-run" depends="init">
		<ant antfile="${donkey}/build.xml" dir="${donkey}" target="test-run"/>
		<ant antfile="${server}/build.xml" dir="${server}" target="test-run"/>
		<ant antfile="${client}/ant-build.xml" dir="${client}" target="test-run"/>
		<ant antfile="${cli}/build.xml" dir="${cli}" target="test-run"/>
	</target>

	<target name="test-run-and-aggregate" depends="test-run" description="Run all tests and aggregate reports">
		<antcall target="aggregate-test-reports"/>
	</target>

	<!-- ========================================================================= -->
	<!-- Aggregated Test Reporting                                                 -->
	<!-- ========================================================================= -->

	<target name="clean-aggregate-reports" depends="init" description="Clean aggregated test reports">
		<property name="aggregate.dir" value="${basedir}/../aggregate-reports"/>
		<delete dir="${aggregate.dir}"/>
		<echo message="Aggregated reports cleaned"/>
	</target>

	<target name="aggregate-init" depends="init">
		<!-- Aggregated report directories -->
		<property name="aggregate.dir" value="${basedir}/../aggregate-reports"/>
		<property name="aggregate.junit.xml" value="${aggregate.dir}/junit-xml"/>
		<property name="aggregate.junit.html" value="${aggregate.dir}/junit-html"/>
		<property name="aggregate.jacoco.exec" value="${aggregate.dir}/jacoco-exec"/>
		<property name="aggregate.jacoco.html" value="${aggregate.dir}/jacoco-html"/>

		<!-- JaCoCo libraries -->
		<path id="jacoco.classpath">
			<fileset dir="${server}/lib/ant">
				<include name="org.jacoco.ant-0.8.8.jar"/>
				<include name="org.jacoco.core-0.8.8.jar"/>
				<include name="org.jacoco.report-0.8.8.jar"/>
				<include name="org.jacoco.agent-0.8.8.jar"/>
				<include name="asm-9.2.jar"/>
				<include name="asm-tree-9.2.jar"/>
				<include name="asm-commons-9.2.jar"/>
			</fileset>
		</path>

		<taskdef uri="antlib:org.jacoco.ant"
				 resource="org/jacoco/ant/antlib.xml"
				 classpathref="jacoco.classpath"/>
	</target>

	<target name="aggregate-junit-reports" depends="aggregate-init" description="Aggregate JUnit test reports from all modules">
		<echo message=""/>
		<echo message="========================================"/>
		<echo message="Aggregating JUnit Test Reports"/>
		<echo message="========================================"/>

		<!-- Create directories -->
		<mkdir dir="${aggregate.junit.xml}"/>
		<mkdir dir="${aggregate.junit.html}"/>

		<!-- Copy all JUnit XML reports from Donkey module -->
		<echo message="Collecting Donkey test reports..."/>
		<copy todir="${aggregate.junit.xml}" failonerror="false">
			<fileset dir="${donkey}/junit-reports" erroronmissingdir="false">
				<include name="TEST-*.xml"/>
			</fileset>
		</copy>

		<!-- Copy all JUnit XML reports from Donkey multi-database tests -->
		<copy todir="${aggregate.junit.xml}" failonerror="false">
			<fileset dir="${donkey}/junit-reports-derby" erroronmissingdir="false">
				<include name="TEST-*.xml"/>
			</fileset>
		</copy>
		<copy todir="${aggregate.junit.xml}" failonerror="false">
			<fileset dir="${donkey}/junit-reports-postgres" erroronmissingdir="false">
				<include name="TEST-*.xml"/>
			</fileset>
		</copy>
		<copy todir="${aggregate.junit.xml}" failonerror="false">
			<fileset dir="${donkey}/junit-reports-mysql" erroronmissingdir="false">
				<include name="TEST-*.xml"/>
			</fileset>
		</copy>
		<copy todir="${aggregate.junit.xml}" failonerror="false">
			<fileset dir="${donkey}/junit-reports-sqlserver" erroronmissingdir="false">
				<include name="TEST-*.xml"/>
			</fileset>
		</copy>
		<copy todir="${aggregate.junit.xml}" failonerror="false">
			<fileset dir="${donkey}/junit-reports-oracle" erroronmissingdir="false">
				<include name="TEST-*.xml"/>
			</fileset>
		</copy>

		<!-- Copy all JUnit XML reports from Server module -->
		<echo message="Collecting Server test reports..."/>
		<copy todir="${aggregate.junit.xml}" failonerror="false">
			<fileset dir="${server}/junit-reports" erroronmissingdir="false">
				<include name="TEST-*.xml"/>
			</fileset>
		</copy>

		<!-- Generate aggregated HTML report -->
		<echo message="Generating aggregated HTML report..."/>
		<junitreport todir="${aggregate.junit.xml}">
			<fileset dir="${aggregate.junit.xml}">
				<include name="TEST-*.xml"/>
			</fileset>
			<report format="frames" todir="${aggregate.junit.html}">
				<param name="TITLE" expression="BridgeLink - All Modules Test Report"/>
			</report>
		</junitreport>

		<echo message=""/>
		<echo message="========================================"/>
		<echo message="JUnit Aggregation Complete!"/>
		<echo message="========================================"/>
		<echo message="Report location: ${aggregate.junit.html}/index.html"/>
		<echo message=""/>
	</target>

	<target name="aggregate-jacoco-reports" depends="aggregate-init" description="Aggregate JaCoCo coverage reports from all modules">
		<echo message=""/>
		<echo message="========================================"/>
		<echo message="Aggregating JaCoCo Coverage Reports"/>
		<echo message="========================================"/>

		<!-- Create directories -->
		<mkdir dir="${aggregate.jacoco.exec}"/>
		<mkdir dir="${aggregate.jacoco.html}"/>

		<!-- Merge all JaCoCo execution data files -->
		<echo message="Merging coverage data..."/>
		<jacoco:merge destfile="${aggregate.jacoco.exec}/merged.exec" xmlns:jacoco="antlib:org.jacoco.ant">
			<!-- Donkey coverage data -->
			<fileset dir="${donkey}" includes="code-coverage-reports/jacoco.exec" erroronmissingdir="false"/>
			<fileset dir="${donkey}" includes="code-coverage-reports-derby/jacoco.exec" erroronmissingdir="false"/>
			<fileset dir="${donkey}" includes="code-coverage-reports-postgres/jacoco.exec" erroronmissingdir="false"/>
			<fileset dir="${donkey}" includes="code-coverage-reports-mysql/jacoco.exec" erroronmissingdir="false"/>
			<fileset dir="${donkey}" includes="code-coverage-reports-sqlserver/jacoco.exec" erroronmissingdir="false"/>
			<fileset dir="${donkey}" includes="code-coverage-reports-oracle/jacoco.exec" erroronmissingdir="false"/>

			<!-- Server coverage data -->
			<fileset dir="${server}" includes="code-coverage-reports/jacoco.exec" erroronmissingdir="false"/>
		</jacoco:merge>

		<!-- Generate aggregated coverage report -->
		<echo message="Generating aggregated coverage report..."/>
		<jacoco:report xmlns:jacoco="antlib:org.jacoco.ant">
			<executiondata>
				<file file="${aggregate.jacoco.exec}/merged.exec"/>
			</executiondata>

			<structure name="BridgeLink - All Modules">
				<!-- Donkey classes and sources -->
				<group name="Donkey Module">
					<classfiles>
						<fileset dir="${donkey}/classes" erroronmissingdir="false">
							<include name="**/*.class"/>
						</fileset>
					</classfiles>
					<sourcefiles encoding="UTF-8">
						<fileset dir="${donkey}/src/main/java" erroronmissingdir="false"/>
					</sourcefiles>
				</group>

				<!-- Server classes and sources -->
				<group name="Server Module">
					<classfiles>
						<fileset dir="${server}/classes" erroronmissingdir="false">
							<include name="**/*.class"/>
						</fileset>
					</classfiles>
					<sourcefiles encoding="UTF-8">
						<fileset dir="${server}/src" erroronmissingdir="false">
							<include name="**/*.java"/>
						</fileset>
					</sourcefiles>
				</group>
			</structure>

			<html destdir="${aggregate.jacoco.html}"/>
			<xml destfile="${aggregate.jacoco.exec}/jacoco-report.xml"/>
			<csv destfile="${aggregate.jacoco.exec}/jacoco-report.csv"/>
		</jacoco:report>

		<echo message=""/>
		<echo message="========================================"/>
		<echo message="JaCoCo Aggregation Complete!"/>
		<echo message="========================================"/>
		<echo message="Report location: ${aggregate.jacoco.html}/index.html"/>
		<echo message=""/>
	</target>

	<target name="aggregate-test-reports" depends="aggregate-junit-reports, aggregate-jacoco-reports" description="Aggregate both JUnit and JaCoCo reports from all modules">
		<echo message=""/>
		<echo message="=========================================="/>
		<echo message="All Reports Aggregated Successfully!"/>
		<echo message="=========================================="/>
		<echo message=""/>
		<echo message="JUnit Test Report:"/>
		<echo message="  ${aggregate.junit.html}/index.html"/>
		<echo message=""/>
		<echo message="JaCoCo Coverage Report:"/>
		<echo message="  ${aggregate.jacoco.html}/index.html"/>
		<echo message=""/>
		<echo message="=========================================="/>
	</target>

	<!-- ========================================================================= -->
	<!-- End Aggregated Test Reporting                                             -->
	<!-- ========================================================================= -->

	<target name="remove-classes" depends="init">
		<ant antfile="${donkey}/build.xml" dir="${donkey}" target="remove-classes"/>
		<ant antfile="${server}/build.xml" dir="${server}" target="remove-classes"/>
		<ant antfile="${client}/ant-build.xml" dir="${client}" target="remove-classes"/>
	</target>

	<!-- build custom extensions: dynamic-lookup-gateway, .... -->
	<target name="build-custom-extensions" depends="init">
		<ant antfile="${custom-extensions}/build.xml" dir="${custom-extensions}" target="build" />
	</target>
</project>
