	<classpathentry kind="lib" path="../../server/lib/log4j/log4j-core-2.17.2.jar"/>
	<classpathentry kind="lib" path="../../server/lib/javax/javax.servlet-api-3.1.0.jar"/>
	<classpathentry kind="lib" path="../../server/lib/javax/javax.ws.rs-api-2.0.1.jar"/>
