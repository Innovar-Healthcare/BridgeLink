			<attribute name="javadoc_location" value="http://www.jarvana.com/jarvana/view/org/swinglabs/swingx-core/1.6.2-2/swingx-core-1.6.2-2-javadoc.jar!/"/>
		</attributes>
	</classpathentry>
	<classpathentry kind="lib" path="../../client/lib/rsyntaxtextarea-2.5.6.jar"/>
	
    <!-- Optional: Add plugin/lib dependencies here -->
	<classpathentry kind="lib" path="libs/jfreechart-1.5.6.jar"/>
    <classpathentry kind="lib" path="libs/opencsv-5.9.jar"/>
	
</classpath>
