<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "conf/dtd/mybatis-3-mapper.dtd">

<mapper namespace="Lookup">
    <resultMap id="lookup-group" type="com.mirth.connect.plugins.dynamiclookup.shared.model.LookupGroup">
        <id property="id" column="ID" javaType="Integer"/>
        <result property="name" column="NAME" javaType="String"/>
        <result property="description" column="DESCRIPTION" javaType="String"/>
        <result property="version" column="VERSION" javaType="String"/>
        <result property="cacheSize" column="CACHE_SIZE" javaType="Integer"/>
        <result property="cachePolicy" column="CACHE_POLICY" javaType="String"/>
        <result property="createdDate" column="CREATED_DATE" javaType="java.sql.Timestamp"/>
        <result property="updatedDate" column="UPDATED_DATE" javaType="java.sql.Timestamp"/>
        <result property="valueType" column="VALUE_TYPE" javaType="String"/>
    </resultMap>

	<resultMap id="lookup-group-extra" type="com.mirth.connect.plugins.dynamiclookup.shared.model.LookupGroupExtra">
        <id     property="groupId"           column="GROUP_ID"            javaType="Integer"/>
        <result property="jsonIndexMode"     column="JSON_INDEX_MODE"     javaType="String"/>
        <result property="indexedJsonFields" column="INDEXED_JSON_FIELDS" javaType="String"/>
    </resultMap>
    
	<resultMap id="lookup-value" type="com.mirth.connect.plugins.dynamiclookup.shared.model.LookupValue">
        <id property="keyValue" column="KEY_VALUE" javaType="String"/>
        <result property="valueData" column="VALUE_DATA" javaType="String"/>
        <result property="createdDate" column="CREATED_DATE" javaType="java.sql.Timestamp"/>
        <result property="updatedDate" column="UPDATED_DATE" javaType="java.sql.Timestamp"/>
    </resultMap>
    
    <resultMap id="lookup-statistics" type="com.mirth.connect.plugins.dynamiclookup.shared.model.LookupStatistics">
        <id property="groupId" column="GROUP_ID" javaType="Integer"/>
        <result property="totalLookups" column="TOTAL_LOOKUPS" javaType="Long"/>
        <result property="cacheHits" column="CACHE_HITS" javaType="Long"/>
        <result property="lastAccessed" column="LAST_ACCESSED" javaType="java.sql.Timestamp"/>
        <result property="resetDate" column="RESET_DATE" javaType="java.sql.Timestamp"/>
    </resultMap>

    <resultMap id="lookup-audit" type="com.mirth.connect.plugins.dynamiclookup.shared.model.LookupAudit">
        <id property="id" column="ID" javaType="Long"/>
        <result property="groupId" column="GROUP_ID" javaType="Integer"/>
        <result property="tableName" column="TABLE_NAME" javaType="String"/>
        <result property="keyValue" column="KEY_VALUE" javaType="String"/>
        <result property="action" column="ACTION" javaType="String"/>
        <result property="oldValue" column="OLD_VALUE" javaType="String"/>
        <result property="newValue" column="NEW_VALUE" javaType="String"/>
        <result property="userId" column="USER_ID" javaType="String"/>
        <result property="timestamp" column="AUDIT_TIMESTAMP" javaType="java.sql.Timestamp"/>
    </resultMap>

    <!-- Group Operations -->
    <select id="getGroupById" parameterType="Integer" resultMap="lookup-group">
        SELECT ID, NAME, DESCRIPTION, VERSION, CACHE_SIZE, CACHE_POLICY, CREATED_DATE, UPDATED_DATE, VALUE_TYPE
        FROM LOOKUP_GROUP
        WHERE ID = #{value}
    </select>

    <select id="getGroupByName" parameterType="String" resultMap="lookup-group">
        SELECT ID, NAME, DESCRIPTION, VERSION, CACHE_SIZE, CACHE_POLICY, CREATED_DATE, UPDATED_DATE, VALUE_TYPE
        FROM LOOKUP_GROUP
        WHERE NAME = #{value}
    </select>

    <select id="getAllGroups" resultMap="lookup-group">
        SELECT ID, NAME, DESCRIPTION, VERSION, CACHE_SIZE, CACHE_POLICY, CREATED_DATE, UPDATED_DATE, VALUE_TYPE
        FROM LOOKUP_GROUP
    </select>

    <insert id="insertGroup" parameterType="map" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO LOOKUP_GROUP (NAME, DESCRIPTION, VERSION, CACHE_SIZE, CACHE_POLICY, VALUE_TYPE)
        VALUES (#{name}, #{description}, #{version}, #{cacheSize}, #{cachePolicy}, #{valueType})
    </insert>

    <update id="updateGroup" parameterType="map">
        UPDATE LOOKUP_GROUP
        SET NAME = #{name},
        DESCRIPTION = #{description},
        VERSION = #{version},
        CACHE_SIZE = #{cacheSize},
        CACHE_POLICY = #{cachePolicy},
        VALUE_TYPE = #{valueType},
        UPDATED_DATE = CURRENT_TIMESTAMP
        WHERE ID = #{id}
    </update>

    <delete id="deleteGroup" parameterType="Integer">
        DELETE FROM LOOKUP_GROUP
        WHERE ID = #{value}
    </delete>

	<select id="getByGroupId" parameterType="Integer" resultMap="lookup-group-extra">
        SELECT GROUP_ID, JSON_INDEX_MODE, INDEXED_JSON_FIELDS
        FROM LOOKUP_GROUP_EXTRA
        WHERE GROUP_ID = #{value}
    </select>

	<select id="getAllGroupExtras" resultMap="lookup-group-extra">
        SELECT GROUP_ID, JSON_INDEX_MODE, INDEXED_JSON_FIELDS
        FROM LOOKUP_GROUP_EXTRA
    </select>
    
    <insert id="insertGroupExtra" parameterType="map">
        INSERT INTO LOOKUP_GROUP_EXTRA 
            (GROUP_ID, JSON_INDEX_MODE, INDEXED_JSON_FIELDS)
        VALUES
            (#{groupId}, #{jsonIndexMode}, #{indexedJsonFields}::jsonb)
    </insert>

    <update id="updateGroupExtra" parameterType="map">
        UPDATE LOOKUP_GROUP_EXTRA
        SET 
            JSON_INDEX_MODE = #{jsonIndexMode},
            INDEXED_JSON_FIELDS = #{indexedJsonFields}::jsonb
        WHERE GROUP_ID = #{groupId}
    </update>

    <select id="groupExtraExists" parameterType="Integer" resultType="Integer">
        SELECT 1
        FROM LOOKUP_GROUP_EXTRA
        WHERE GROUP_ID = #{value}
    </select>
	
	<!-- Value Operations -->
    <sql id="searchLookupValuesBody">
	    <trim prefix="WHERE" prefixOverrides="AND |OR ">
	        <if test="keyFilter != null and keyFilter != ''">
	            <choose>
	                <when test="keyFilterMode == 'EXACT'">
	                    AND KEY_VALUE = #{keyFilter}
	                </when>
	                <when test="keyFilterMode == 'PREFIX'">
	                    AND KEY_VALUE ILIKE #{keyFilter} || '%'
	                </when>
	                <when test="keyFilterMode == 'PATTERN'">
	                    AND KEY_VALUE ILIKE #{keyFilter}
	                </when>
	                <otherwise>
	                    AND KEY_VALUE ILIKE '%' || #{keyFilter} || '%'
	                </otherwise>	
	            </choose>
	        </if>
	        <if test="valueFilter != null and valueFilter != ''">
	            AND VALUE_DATA::text ILIKE '%' || #{valueFilter} || '%'
	        </if>
	    </trim>
	</sql>
    
<!--
    <sql id="searchByJsonFieldsFieldBody">
	    <trim prefix="WHERE" prefixOverrides="AND |OR ">
	        <if test="keyPattern != null and keyPattern != ''">
	            AND KEY_VALUE ILIKE #{keyPattern}
	        </if>
	        <if test="criteria != null and criteria.size() > 0">
			    AND (
			        <foreach collection="criteria"
			                 item="c"
			                 separator=" AND ">
			            ${c.expression} ${c.operatorSql} #{c.value}
			        </foreach>
			    )
			</if>
	    </trim>
	</sql>
 -->
 
	<sql id="searchByJsonFieldsFieldBody">
	    <trim prefix="WHERE" prefixOverrides="AND |OR ">
	        <!-- Key filter -->
	        <if test="keyPattern != null and keyPattern != ''">
	            AND KEY_VALUE ILIKE #{keyPattern}
	        </if>
	
	        <!-- JSON criteria (FIELD or merged GIN) -->
	        <if test="criteria != null and criteria.size() > 0">
	            AND (
	                <foreach collection="criteria"
	                         item="c"
	                         separator=" AND ">
	                    <choose>
	                        <!-- GIN merged criterion -->
	                        <when test="c.operatorSql == '@>'">
	                            ${c.expression} @> #{c.value}::jsonb
	                        </when>
	
	                        <!-- Normal FIELD comparison -->
	                        <otherwise>
	                            ${c.expression} ${c.operatorSql} #{c.value}
	                        </otherwise>
	                    </choose>
	                </foreach>
	            )
	        </if>
	    </trim>
	</sql>


    <sql id="commonOrderByLimitOffset">
	    ORDER BY KEY_VALUE ASC
	    <if test="offset != null">
            OFFSET #{offset}
        </if>
        <if test="limit != null">
            LIMIT #{limit}
        </if>
	</sql>

    <select id="getLookupValues" parameterType="map" resultMap="lookup-value">
        SELECT KEY_VALUE, VALUE_DATA, CREATED_DATE, UPDATED_DATE
        FROM ${tableName}
        ORDER BY KEY_VALUE ASC
    </select>

    <select id="getLookupValue" parameterType="map" resultMap="lookup-value">
        SELECT KEY_VALUE, VALUE_DATA, CREATED_DATE, UPDATED_DATE
        FROM ${tableName}
        WHERE KEY_VALUE = #{keyValue}
    </select>

    <select id="getMatchingLookupValues" parameterType="map" resultMap="lookup-value">
        SELECT KEY_VALUE, VALUE_DATA
        FROM ${tableName}
        WHERE KEY_VALUE ILIKE '%' || #{keyPattern} || '%'
        
        <include refid="commonOrderByLimitOffset"/>
    </select>

	<select id="getMatchingLookupValuesCount" parameterType="map" resultType="long">
	    SELECT COUNT(*)
	    FROM ${tableName}
	    WHERE KEY_VALUE ILIKE '%' || #{keyPattern} || '%'
	</select>

    <select id="getValue" parameterType="map" resultType="String">
        SELECT VALUE_DATA
        FROM ${tableName}
        WHERE KEY_VALUE = #{keyValue}
    </select>

    <insert id="insertValue" parameterType="map">
        INSERT INTO ${tableName} (KEY_VALUE, VALUE_DATA)
        VALUES (#{keyValue}, #{valueData})
    </insert>

    <update id="updateValue" parameterType="map">
        UPDATE ${tableName}
        SET VALUE_DATA = #{valueData},
        UPDATED_DATE = CURRENT_TIMESTAMP
        WHERE KEY_VALUE = #{keyValue}
    </update>
    
	<insert id="putIfAbsent" parameterType="map">
    	INSERT INTO ${tableName} (KEY_VALUE, VALUE_DATA)
    	VALUES (#{keyValue}, #{valueData})
    	ON CONFLICT (KEY_VALUE) DO NOTHING
  	</insert>

	<update id="compareAndSwap" parameterType="map">
	    UPDATE ${tableName}
	    SET VALUE_DATA = #{newValue},
	    UPDATED_DATE = CURRENT_TIMESTAMP
	    WHERE KEY_VALUE = #{keyValue} AND VALUE_DATA = #{expectedValue}
	</update>

	<update id="updateValueByDelta" parameterType="map">
	    UPDATE ${tableName}
	    SET VALUE_DATA = ((VALUE_DATA)::bigint + #{delta})::text,
	    UPDATED_DATE = CURRENT_TIMESTAMP
	    WHERE KEY_VALUE = #{keyValue}
	</update>
	
    <delete id="deleteValue" parameterType="map">
        DELETE FROM ${tableName}
        WHERE KEY_VALUE = #{keyValue}
    </delete>

    <delete id="deleteAllValues" parameterType="map">
        DELETE FROM ${tableName}
    </delete>

    <select id="getValueCount" parameterType="map" resultType="long">
        SELECT COUNT(*) FROM ${tableName}
    </select>

    <update id="createLookupValueTable" parameterType="map">
        CREATE TABLE ${tableName} (
        KEY_VALUE VARCHAR(255) NOT NULL,
        VALUE_DATA TEXT,
        CREATED_DATE TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
        UPDATED_DATE TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
        PRIMARY KEY (KEY_VALUE)
        )
    </update>

    <update id="dropLookupValueTable" parameterType="map">
        DROP TABLE IF EXISTS ${tableName};
    </update>

    <select id="searchLookupValuesCount" parameterType="map" resultType="long">
        SELECT COUNT(*) FROM ${tableName}

        <include refid="searchLookupValuesBody"/>
    </select>

    <select id="searchLookupValues" parameterType="map" resultMap="lookup-value">
        SELECT KEY_VALUE, VALUE_DATA, CREATED_DATE, UPDATED_DATE
        FROM ${tableName}

        <include refid="searchLookupValuesBody"/>

        <include refid="commonOrderByLimitOffset"/>
    </select>
  
   	<select id="selectExistingKeys" parameterType="map" resultType="string">
	    SELECT KEY_VALUE
	    FROM ${tableName}
	    WHERE KEY_VALUE IN
	    <foreach item="key" collection="keyValues" open="(" separator="," close=")">
	      #{key}
	    </foreach>
  	</select>
  	
  	<!-- JSON Value Operations -->
  	<update id="createLookupValueJsonTable" parameterType="map">
        CREATE TABLE ${tableName} (
        KEY_VALUE VARCHAR(255) NOT NULL,
        VALUE_DATA JSONB,
        CREATED_DATE TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
        UPDATED_DATE TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
        PRIMARY KEY (KEY_VALUE)
        )
    </update>
    
  	<insert id="insertValueJson" parameterType="map">
	    INSERT INTO ${tableName} (KEY_VALUE, VALUE_DATA)
    	VALUES (#{keyValue}, #{valueData}::jsonb)
	</insert>
	
	<update id="updateValueJson" parameterType="map">
	    UPDATE ${tableName}
	    SET VALUE_DATA = #{valueData}::jsonb,
	        UPDATED_DATE = CURRENT_TIMESTAMP
	    WHERE KEY_VALUE = #{keyValue}
	</update>

	<insert id="putIfAbsentJson" parameterType="map">
	    INSERT INTO ${tableName} (KEY_VALUE, VALUE_DATA)
	    VALUES (#{keyValue}, #{valueData}::jsonb)
	    ON CONFLICT (KEY_VALUE) DO NOTHING
	</insert>
	
	<update id="compareAndSwapJson" parameterType="map">
	    UPDATE ${tableName}
	    SET VALUE_DATA = #{newValue}::jsonb,
	        UPDATED_DATE = CURRENT_TIMESTAMP
	    WHERE KEY_VALUE = #{keyValue}
	      AND VALUE_DATA = #{expectedValue}::jsonb
	</update>

	<update id="createJsonGinIndex" parameterType="map">
	    CREATE INDEX IF NOT EXISTS ${indexName}
	    ON ${tableName}
	    USING gin (VALUE_DATA);
	</update>

    <update id="dropJsonGinIndex" parameterType="map">
    	DROP INDEX IF EXISTS ${indexName};
	</update>

	<update id="createJsonFieldIndexes" parameterType="map">
	    <foreach collection="fieldIndexes" item="idx" separator=";">
            CREATE INDEX IF NOT EXISTS ${idx.indexName}
            ON ${tableName} (( ${idx.expression} ))
        </foreach>
	</update>

	<update id="dropJsonFieldIndexes" parameterType="map">
        <foreach collection="fieldIndexes" item="idx" separator=";">
            DROP INDEX IF EXISTS ${idx.indexName}
        </foreach>
    </update>
    	
	<select id="searchByJsonFieldsFieldCount" parameterType="map" resultType="long">
        SELECT COUNT(*) FROM ${tableName}

        <include refid="searchByJsonFieldsFieldBody"/>
    </select>
    
	<select id="searchByJsonFieldsField" parameterType="map" resultMap="lookup-value">
	    SELECT KEY_VALUE, VALUE_DATA, CREATED_DATE, UPDATED_DATE
        FROM ${tableName}
	    
	    <include refid="searchByJsonFieldsFieldBody"/>
	    <include refid="commonOrderByLimitOffset"/>
	</select>
	<!-- End Value Operations -->
	
    <!-- Statistics Operations -->
    <insert id="insertStatistics" parameterType="map">
        INSERT INTO LOOKUP_STATISTICS (
        GROUP_ID, TOTAL_LOOKUPS, CACHE_HITS, LAST_ACCESSED, RESET_DATE ) VALUES ( #{groupId}, 0, 0, NULL, NULL )
    </insert>

    <select id="getStatistics" parameterType="Integer" resultMap="lookup-statistics">
        SELECT GROUP_ID, TOTAL_LOOKUPS, CACHE_HITS, LAST_ACCESSED, RESET_DATE
        FROM LOOKUP_STATISTICS
        WHERE GROUP_ID = #{value}
    </select>

    <update id="updateStatistics" parameterType="map">
        UPDATE LOOKUP_STATISTICS
        SET
        TOTAL_LOOKUPS = TOTAL_LOOKUPS + 1,
        CACHE_HITS = CACHE_HITS +
        <choose>
            <when test="cacheHit">1</when>
            <otherwise>0</otherwise>
        </choose>
        ,
        LAST_ACCESSED = #{lastAccessed}
        WHERE GROUP_ID = #{groupId}
    </update>

    <update id="resetStatistics" parameterType="map">
        UPDATE LOOKUP_STATISTICS
        SET
        TOTAL_LOOKUPS = 0,
        CACHE_HITS = 0,
        LAST_ACCESSED = NULL,
        RESET_DATE = #{resetDate}
        WHERE GROUP_ID = #{groupId}
    </update>

    <!-- AuditEntry Operations -->
    <insert id="insertAuditEntry" parameterType="map">
        INSERT INTO LOOKUP_AUDIT (
        GROUP_ID, TABLE_NAME, KEY_VALUE, ACTION, OLD_VALUE, NEW_VALUE, USER_ID, AUDIT_TIMESTAMP
        ) VALUES (
        #{groupId}, #{tableName}, #{keyValue}, #{action}, #{oldValue}, #{newValue}, #{userId}, CURRENT_TIMESTAMP
        )
    </insert>

    <select id="getAuditEntriesByGroup" parameterType="map" resultMap="lookup-audit">
        SELECT *
        FROM LOOKUP_AUDIT

        WHERE GROUP_ID = #{groupId}

        <if test="offset != null">
            OFFSET ${offset}
        </if>
        <if test="limit != null">
            LIMIT ${limit}
        </if>
    </select>

    <select id="getAuditEntryCount" parameterType="map" resultType="long">
        SELECT COUNT(*)
        FROM LOOKUP_AUDIT
        WHERE GROUP_ID = #{groupId}
    </select>

    <sql id="searchAuditEntriesBody">
        <where>
            GROUP_ID = #{groupId}
            <if test="keyValue != null and keyValue != ''">
                AND KEY_VALUE ILIKE '%' || #{keyValue} || '%'
            </if>
            <if test="action != null and action != ''">
                AND ACTION = #{action}
            </if>
            <if test="userId != null and userId != ''">
                AND USER_ID = #{userId}
            </if>
            <if test="startDate != null">
                AND AUDIT_TIMESTAMP <![CDATA[ >= ]]> #{startDate}
            </if>
            <if test="endDate != null">
                AND AUDIT_TIMESTAMP <![CDATA[ <= ]]> #{endDate}
            </if>
        </where>
    </sql>

    <select id="searchAuditEntriesByGroup" parameterType="map" resultMap="lookup-audit">
        SELECT *
        FROM LOOKUP_AUDIT

        <include refid="searchAuditEntriesBody"/>

        ORDER BY AUDIT_TIMESTAMP DESC

        <if test="offset != null">
            OFFSET ${offset}
        </if>
        <if test="limit != null">
            LIMIT ${limit}
        </if>
    </select>

    <select id="searchAuditEntryCount" parameterType="map" resultType="long">
        SELECT COUNT(*)
        FROM LOOKUP_AUDIT
        <include refid="searchAuditEntriesBody"/>
    </select>

	<delete id="deleteAuditEntriesBefore" parameterType="map">
        DELETE FROM LOOKUP_AUDIT
        WHERE AUDIT_TIMESTAMP <![CDATA[ < ]]> #{cutoff}
    </delete>
</mapper>
