<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<pluginMetaData path="innovarhealthcare-oidc">
    <name>OIDC Authentication</name>
    <author>Daniel Svanstedt, Thai Tran</author>
    <pluginVersion>1.0.0</pluginVersion>
    <mirthVersion>4.6.0, 4.6.1, 26.3.1, 26.6.0</mirthVersion>
    <url>https://www.innovarhealthcare.com</url>
    <description>This plugin provides OpenID Connect (OIDC) Single Sign-On authentication for BridgeLink</description>
    <clientClasses>
        <string>com.mirth.connect.plugins.oidc.client.plugin.OIDCClientPlugin</string>
    </clientClasses>
    <serverClasses>
        <string>com.mirth.connect.plugins.oidc.server.plugin.OIDCAuthorizationPlugin</string>
    </serverClasses>
    <library path="oidc-server.jar" type="SERVER"/>
    <library path="oidc-shared.jar" type="SHARED"/>
    <library path="oidc-client.jar" type="CLIENT"/>
    
    <library path="libs/nimbus-jose-jwt-9.37.4.jar" type="SERVER"/>
    <library path="libs/oauth2-oidc-sdk-11.10.1.jar" type="SERVER"/>
    <library path="libs/accessors-smart-2.5.0.jar" type="SERVER"/>
    <library path="libs/json-smart-2.5.0.jar" type="SERVER"/>
    <library path="libs/content-type-2.3.jar" type="SERVER"/>
    <library path="libs/lang-tag-1.7.jar" type="SERVER"/>
    
    <library path="libs/nimbus-jose-jwt-9.37.4.jar" type="SHARED"/>
    <library path="libs/oauth2-oidc-sdk-11.10.1.jar" type="SHARED"/>
    <library path="libs/accessors-smart-2.5.0.jar" type="SHARED"/>
    <library path="libs/json-smart-2.5.0.jar" type="SHARED"/>
    <library path="libs/content-type-2.3.jar" type="SHARED"/>
    <library path="libs/lang-tag-1.7.jar" type="SHARED"/>
        
    <apiProvider name="com.mirth.connect.plugins.oidc.shared.interfaces.OIDCServletInterface" type="SERVLET_INTERFACE"/>
    <apiProvider name="com.mirth.connect.plugins.oidc.server.servlet.OIDCServlet" type="SERVER_CLASS"/>
</pluginMetaData>
